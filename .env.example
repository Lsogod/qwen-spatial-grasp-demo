# Default demo path
VLM_METHOD=qwen

# Planner provider for vision_agent.py
# qwen: Qwen plans actions and grounds target parts
# azure: keep the previous Azure-compatible planner behavior
ACTION_MODEL_PROVIDER=qwen

# Qwen / ModelScope-compatible endpoint
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_API_KEY=<your-modelscope-key>
MODELSCOPE_MODEL_ID=qwen3-vl-plus-2025-12-19

# Optional: SVP fallback pipeline (vision_agent_v2.py)
BACKEND_URL=http://127.0.0.1:8000
AZURE_ENDPOINT=https://<your-endpoint>.openai.azure.com
AZURE_DEPLOYMENT=<your-deployment>
AZURE_API_VERSION=2024-02-15-preview
AZURE_KEY=<your-azure-key>

# Optional: only needed when ACTION_MODEL_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://<your-endpoint>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-azure-key>
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_API_VERSION=2024-08-01-preview
